  app.post("/api/clips/:id/likes", authMiddleware, async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      const user = (req as any).user;
      
      const clip = await storage.getClip(clipId);
      
      if (!clip) {
        return res.status(404).json({ message: "Clip not found" });
      }
      
      const likeData = insertLikeSchema.parse({
        userId: user.id,
        clipId: clipId
      });
      
      try {
        const like = await storage.createLike(likeData);
        res.status(201).json(like);
      } catch (error) {
        // User already liked this clip
        res.status(409).json({ message: "Already liked" });
      }
    } catch (err) {
      handleValidationError(err, res);
    }
  });

  app.delete("/api/clips/:id/likes", authMiddleware, async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      const user = (req as any).user;
      
      const result = await storage.deleteLike(user.id, clipId);
      
      if (!result) {
        return res.status(404).json({ message: "Like not found" });
      }
      
      res.status(204).send();
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  app.get("/api/clips/:id/likes", async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      const likes = await storage.getLikesByClipId(clipId);
      res.json(likes);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  // Comment routes
  app.post("/api/clips/:id/comments", authMiddleware, async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      const user = (req as any).user;
      
      const clip = await storage.getClip(clipId);
      
      if (!clip) {
        return res.status(404).json({ message: "Clip not found" });
      }
      
      const commentData = insertCommentSchema.parse({
        userId: user.id,
        clipId: clipId,
        content: req.body.content
      });
      
      const comment = await storage.createComment(commentData);
      res.status(201).json(comment);
    } catch (err) {
      handleValidationError(err, res);
    }
  });

  app.get("/api/clips/:id/comments", async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      const comments = await storage.getCommentsByClipId(clipId);
      res.json(comments);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  app.delete("/api/comments/:id", authMiddleware, async (req, res) => {
    try {
      const commentId = parseInt(req.params.id);
      const user = (req as any).user;
      
      const comment = await storage.getComment(commentId);
      
      if (!comment) {
        return res.status(404).json({ message: "Comment not found" });
      }
      
      // Only allow users to delete their own comments
      if (comment.userId !== user.id) {
        return res.status(403).json({ message: "Forbidden" });
      }
      
      const result = await storage.deleteComment(commentId);
      
      if (!result) {
        return res.status(500).json({ message: "Failed to delete comment" });
      }
      
      res.status(204).send();
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  // Follow routes
  app.post("/api/users/:username/follow", authMiddleware, async (req, res) => {
    try {
      const username = req.params.username;
      const user = (req as any).user;
      
      const userToFollow = await storage.getUserByUsername(username);
      
      if (!userToFollow) {
        return res.status(404).json({ message: "User not found" });
      }
      
      // Cannot follow yourself
      if (user.id === userToFollow.id) {
        return res.status(400).json({ message: "Cannot follow yourself" });
      }
      
      const followData = insertFollowSchema.parse({
        followerId: user.id,
        followingId: userToFollow.id
      });
      
      try {
        const follow = await storage.createFollow(followData);
        res.status(201).json(follow);
      } catch (error) {
        // Already following
        res.status(409).json({ message: "Already following" });
      }
    } catch (err) {
      handleValidationError(err, res);
    }
  });

  app.delete("/api/users/:username/follow", authMiddleware, async (req, res) => {
    try {
      const username = req.params.username;
      const user = (req as any).user;
      
      const userToUnfollow = await storage.getUserByUsername(username);
      
      if (!userToUnfollow) {
        return res.status(404).json({ message: "User not found" });
      }
      
      const result = await storage.deleteFollow(user.id, userToUnfollow.id);
      
      if (!result) {
        return res.status(404).json({ message: "Not following" });
      }
      
      res.status(204).send();
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  app.get("/api/users/:username/followers", async (req, res) => {
    try {
      const username = req.params.username;
      const user = await storage.getUserByUsername(username);
      
      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }
      
      const followers = await storage.getFollowersByUserId(user.id);
      res.json(followers);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  app.get("/api/users/:username/following", async (req, res) => {
    try {
      const username = req.params.username;
      const user = await storage.getUserByUsername(username);
      
      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }
      
      const following = await storage.getFollowingByUserId(user.id);
      res.json(following);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  // User game favorites routes
  app.post("/api/users/games/favorites", authMiddleware, async (req, res) => {
    try {
      const user = (req as any).user;
      const gameId = parseInt(req.body.gameId);
      
      const game = await storage.getGame(gameId);
      
      if (!game) {
        return res.status(404).json({ message: "Game not found" });
      }
      
      const favoriteData = insertUserGameFavoriteSchema.parse({
        userId: user.id,
        gameId: gameId
      });
      
      try {
        const favorite = await storage.addUserGameFavorite(favoriteData);
        res.status(201).json(favorite);
      } catch (error) {
        // Already favorited
        res.status(409).json({ message: "Game already in favorites" });
      }
    } catch (err) {
      handleValidationError(err, res);
    }
  });

  app.delete("/api/users/games/favorites/:gameId", authMiddleware, async (req, res) => {
    try {
      const user = (req as any).user;
      const gameId = parseInt(req.params.gameId);
      
      const result = await storage.removeUserGameFavorite(user.id, gameId);
      
      if (!result) {
        return res.status(404).json({ message: "Game not in favorites" });
      }
      
      res.status(204).send();
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  app.get("/api/users/:username/games/favorites", async (req, res) => {
    try {
      const username = req.params.username;
      
      // Special handling for demo user
      if (username === "demo") {
        console.log("Serving demo user favorites");
        return res.json(getDemoFavoriteGames());
      }
      
      const user = await storage.getUserByUsername(username);
      
      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }
      
      const favorites = await storage.getUserGameFavorites(user.id);
      res.json(favorites);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  // Profile banners routes
  app.get("/api/profile-banners", async (req, res) => {
    try {
      const banners = await storage.getAllProfileBanners();
      res.json(banners);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });
  
  // Reset banners (development only)
  if (process.env.NODE_ENV === "development") {
    app.post("/api/reset-banners", async (req, res) => {
      try {
        // Create gaming banners data 
        const bannerData = [
          { name: 'Gaming Controller', imageUrl: '/uploads/banners/gaming-controller.jpg', category: 'gaming' },
          { name: 'Esports Arena', imageUrl: '/uploads/banners/esports-arena.png', category: 'gaming' },
          { name: 'Gaming Keyboard', imageUrl: '/uploads/banners/gaming-keyboard.png', category: 'gaming' },
          { name: 'Gaming Setup', imageUrl: '/uploads/banners/gaming-setup.png', category: 'gaming' },
          { name: 'Gaming Console', imageUrl: '/uploads/banners/gaming-console.png', category: 'gaming' },
          { name: 'Cyberpunk City', imageUrl: '/uploads/banners/cyberpunk-city.png', category: 'gaming' },
          { name: 'Space Battle', imageUrl: '/uploads/banners/space-battle.png', category: 'gaming' },
          { name: 'Neon Arcade', imageUrl: 'https://images.unsplash.com/photo-1511512578047-dfb367046420?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1200&h=300', category: 'abstract' },
          { name: 'Abstract Neon', imageUrl: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1200&h=300', category: 'abstract' },
        ];
        
        // Delete existing banners
        await db.delete(profileBanners);
        
        // Insert new banners
        const result = await db.insert(profileBanners).values(bannerData).returning();
        
        res.json({ message: `Reset ${result.length} profile banners.` });
      } catch (err) {
        console.error(err);
        res.status(500).json({ message: "Internal server error" });
      }
    });
  }

  app.get("/api/profile-banners/categories/:category", async (req, res) => {
    try {
      const category = req.params.category;
      const banners = await storage.getProfileBannersByCategory(category);
      res.json(banners);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  // Return the server
  return httpServer;
}
