modules = ["nodejs-20", "web", "bun", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq", "ffmpeg", "nodejs_20", "unzip"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CHOKIDAR_USEPOLLING=true npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
integrations = ["stripe:2.0.0"]

[userenv]

[userenv.shared]
STRIPE_PRO_MONTHLY_PRICE_ID = "price_1Sy9xoDVcn8w8LmscNqJUGjn"
STRIPE_PRO_YEARLY_PRICE_ID = "price_1Sy9ysDVcn8w8LmsHzCQUjbs"
GFT_TOKEN_CONTRACT_ADDRESS = "0x2Db1fFAbbc41b8667B408a5F5e0E42bB6c6BA7f7"
SKALE_NEBULA_RPC_URL = "https://testnet.skalenodes.com/v1/lanky-ill-funny-testnet"

[userenv.development]
APP_BASE_URL = "https://c9fa12a0-25f6-499c-85a1-3fdaf44e555f-00-2i2gmevrrbqn1.riker.replit.dev"

[userenv.production]
APP_BASE_URL = "https://app.gamefolio.com"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
