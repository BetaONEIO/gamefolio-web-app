  // Clip routes
  app.get("/api/clips", async (req, res) => {
    try {
      const period = req.query.period as string || 'day';
      const type = req.query.type as string || 'feed';
      const gameId = req.query.gameId ? parseInt(req.query.gameId as string) : null;
      const gameSlug = req.query.gameSlug as string || null;
      const limit = req.query.limit ? parseInt(req.query.limit as string) : 10;
      
      let clips;
      
      // Filter by game if gameId or gameSlug is provided
      if (gameId || gameSlug) {
        console.log("Filtering clips by game:", gameId || gameSlug);
        let gameClips = [];
        
        // If we have a gameId, use it directly
        if (gameId) {
          gameClips = await storage.getClipsByGameId(gameId, 50);
        } 
        // If we have a gameSlug, we need to find the game first
        else if (gameSlug) {
          // Look for games by matching name or slug
          console.log("Searching for game with slug:", gameSlug);
          const games = await storage.searchGames(gameSlug);
          console.log("Found games:", games);
          
          // Try to find games by multiple matching strategies
          let matchingGame = games.find(g => {
            const gameNameSlug = g.name.toLowerCase().replace(/[^a-z0-9]+/g, '-');
            const requestSlug = gameSlug.toLowerCase();
            
            return gameNameSlug === requestSlug || 
                   g.name.toLowerCase() === requestSlug ||
                   gameNameSlug.includes(requestSlug) ||
                   requestSlug.includes(gameNameSlug);
          });
          
          if (matchingGame) {
            gameClips = await storage.getClipsByGameId(matchingGame.id, 50);
          }
        }
        
        // Apply sorting based on type
        if (type === 'latest' && gameClips.length > 0) {
          clips = gameClips.sort((a, b) => 
            new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
          );
        } else if (type === 'popular' && gameClips.length > 0) {
          clips = gameClips.sort((a, b) => (b.views || 0) - (a.views || 0));
        } else {
          clips = gameClips;
        }
        
        // Apply limit
        if (clips && clips.length > 0) {
          clips = clips.slice(0, limit);
        }
      }
      // Get different types of clips based on the requested type
      else if (type === 'latest') {
        console.log("Fetching latest clips, limit:", limit);
        clips = await storage.getFeedClips('day', limit);
        // Sort by newest first
        clips.sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());
      } 
      else if (type === 'popular') {
        console.log("Fetching popular clips, limit:", limit);
        // Get a larger set of clips to work with
        const allClips = await storage.getFeedClips('month', 50);
        
        // Sort by views (and eventually likes for a better popularity metric)
        clips = allClips
          .sort((a, b) => (b.views || 0) - (a.views || 0))
          .slice(0, limit);
      }
      else {
        // Default feed behavior - get clips by time period
        console.log("Fetching feed clips, period:", period, "limit:", limit);
        clips = await storage.getFeedClips(period, limit);
      }
      
      // If no clips were found, create some sample clips
      if (!clips || clips.length === 0) {
        console.log("No clips found, creating sample clips");
        // First, we'll force creation of sample data
        const user = await storage.getUserByUsername("DavidvGoliath") || await storage.getUser(1);
        const games = await storage.getAllGames();
        
        if (user && games.length > 0) {
          // Create sample clips
          const clip1 = await storage.createClip({
            userId: user.id,
            gameId: games[0].id,
            title: "Bloody kill streak in COD",
            description: "Dominated this lobby with a 15 kill streak!",
            videoUrl: "/attached_assets/game-controller-5619105_1920.jpg", // Placeholder
            duration: 60,
            trimStart: 0,
            trimEnd: 60
          });
          
          // Add some views to make it popular
          for (let i = 0; i < 5; i++) {
            await storage.incrementClipViews(clip1.id);
          }
          
          // Get the updated clips
          clips = await storage.getFeedClips(period, limit);
        }
      }
      
      res.json(clips);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  app.get("/api/clips/:id", async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      
      // Special handling for uploaded clips (IDs 10000+)
      if (clipId >= 10000) {
        console.log("Getting uploaded clip:", clipId);
        // Get clip data from the uploads
        const uploadDir = path.resolve(process.cwd(), "uploads");
        const files = fs.readdirSync(uploadDir)
          .filter(file => file.endsWith('.mp4'));
          
        // Get the file index from the ID (ID 10000 = first file)
        const fileIndex = clipId - 10000;
        if (fileIndex >= 0 && fileIndex < files.length) {
          const fileName = files[fileIndex];
          const fileNameWithoutExt = fileName.split('.')[0];
          const videoUrl = `/uploads/${fileName}`;
          const thumbnailPath = `/uploads/thumbnails/${fileNameWithoutExt}_thumbnail.jpg`;
          
          const demoUser = getDemoUser();
          const clip = {
            id: clipId,
            userId: demoUser.id,
            title: `Gameplay Clip ${fileIndex + 1}`,
            description: "Your uploaded gameplay clip",
            videoUrl: videoUrl,
            thumbnailUrl: thumbnailPath,
            duration: 15,
            views: Math.floor(Math.random() * 1000),
            likes: Math.floor(Math.random() * 100),
            gameId: 6252,
            createdAt: new Date(parseInt(fileNameWithoutExt.split('-')[0])),
            updatedAt: new Date(),
            trimStart: null,
            trimEnd: null,
            tags: ["gameplay"],
            filter: "none",
            user: demoUser,
            game: {
              id: 6252,
              name: "Gears of War",
              imageUrl: "/attached_assets/game-controller-5619105_1920.jpg",
              createdAt: new Date(2022, 0, 1)
            }
          };
          
          return res.json(clip);
        }
      } 
      
      // Special handling for demo user clips (IDs 100+)
      if (clipId >= 100 && clipId < 1000) {
        console.log("Getting demo clip:", clipId);
        // Get demo clip data
        const demoClips = getDemoClips();
        const demoClip = demoClips.find(c => c.id === clipId);
        
        if (demoClip) {
          // Return demo clip
          return res.json(demoClip);
        }
      }
      
      // Regular clip handling
      const clip = await storage.getClipWithUser(clipId);
      
      if (!clip) {
        return res.status(404).json({ message: "Clip not found" });
      }
      
      // Increment views
      await storage.incrementClipViews(clipId);
      
      res.json(clip);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

  app.post("/api/clips", upload.single("video"), async (req, res) => {
    try {
      let user = (req as any).user;
      
      // Special handling for demo user
      const userId = req.headers["x-user-id"];
      if (userId === "999") {
        // Use the demo user for uploads
        user = getDemoUser();
        console.log("Using demo user for clip upload");
        // Make sure userId is 999 for the demo user
        req.body.userId = 999;
      } else if (!user) {
        return res.status(401).json({ message: "User not found" });
      }
      
      if (!req.file) {
        return res.status(400).json({ message: "Video file is required" });
      }
      
      // Get full path to the uploaded video file
      const videoPath = req.file.path;
      const videoUrl = `/uploads/${req.file.filename}`;
      
      // Generate a thumbnail for the uploaded video
      let thumbnailUrl = '';
      try {
        thumbnailUrl = await generateThumbnail(videoPath);
        console.log(`Generated thumbnail: ${thumbnailUrl}`);
      } catch (error) {
        console.error('Failed to generate thumbnail:', error);
        // Continue with upload even if thumbnail generation fails
      }
      
      // Parse tags if provided
      let tags = [];
      if (req.body.tags) {
        try {
          // If tags are sent as a JSON string, parse them
          tags = typeof req.body.tags === 'string' ? JSON.parse(req.body.tags) : req.body.tags;
          console.log("Parsed tags:", tags);
        } catch (e) {
          console.error("Error parsing tags:", e);
        }
      }
      
      // Merge form data with file information
      const clipData = {
        ...req.body,
        userId: req.body.userId || user.id, // Use the explicitly set userId for demo user
        videoUrl,
        thumbnailUrl, // Add the thumbnail URL
        gameId: req.body.gameId ? parseInt(req.body.gameId) : null,
        duration: req.body.duration ? parseInt(req.body.duration) : 0,
        trimStart: req.body.trimStart ? parseInt(req.body.trimStart) : 0,
        trimEnd: req.body.trimEnd ? parseInt(req.body.trimEnd) : 0,
        tags: tags
      };
      
      console.log(`Creating clip for user ID: ${clipData.userId} (demo user? ${clipData.userId === 999})`);
      
      console.log("Creating clip with data:", {
        ...clipData,
        // Don't log the whole file content
        video: req.file ? `${req.file.originalname} (${req.file.size} bytes)` : null
      });
      
      const parsedData = insertClipSchema.parse(clipData);
      const clip = await storage.createClip(parsedData);
      
      // For uploaded clips, save metadata alongside the video file to remember the game selection
      if (req.file) {
        const metadataPath = path.join(
          uploadDir,
          path.basename(req.file.path, path.extname(req.file.path)) + '_metadata.json'
        );
        
        try {
          // Save metadata including game selection
          const metadata = {
            clipId: clip.id,
            userId: clip.userId,
            title: clip.title,
            gameId: clip.gameId,
            uploadDate: new Date().toISOString()
          };
          
          fs.writeFileSync(metadataPath, JSON.stringify(metadata, null, 2));
          console.log(`Saved clip metadata to ${metadataPath}`);
        } catch (error) {
          console.error('Error saving clip metadata:', error);
          // Continue even if metadata saving fails
        }
      }
      
      res.status(201).json(clip);
    } catch (err) {
      // If validation fails, delete the uploaded file and its thumbnail
      if (req.file) {
        try {
          fs.unlinkSync(req.file.path);
          // Try to delete thumbnail if it exists
          const thumbnailPath = path.join(
            uploadDir, 
            path.basename(req.file.path, path.extname(req.file.path)) + '_thumbnail.jpg'
          );
          if (fs.existsSync(thumbnailPath)) {
            fs.unlinkSync(thumbnailPath);
          }
        } catch (e) {
          console.error('Error cleaning up files:', e);
        }
      }
      handleValidationError(err, res);
    }
  });

  app.delete("/api/clips/:id", authMiddleware, async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      const user = (req as any).user;
      
      const clip = await storage.getClip(clipId);
      
      if (!clip) {
        return res.status(404).json({ message: "Clip not found" });
      }
      
      // Only allow users to delete their own clips
      if (clip.userId !== user.id) {
        return res.status(403).json({ message: "Forbidden" });
      }
      
      const result = await storage.deleteClip(clipId);
      
      if (!result) {
        return res.status(500).json({ message: "Failed to delete clip" });
      }
      
      res.status(204).send();
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });
  
  // Clip editing endpoint (filters, trimming)
  app.post("/api/clips/:id/edit", authMiddleware, async (req, res) => {
    try {
      const clipId = parseInt(req.params.id);
      const user = (req as any).user;
      
      const clip = await storage.getClip(clipId);
      
      if (!clip) {
        return res.status(404).json({ message: "Clip not found" });
      }
      
      // Only allow users to edit their own clips
      if (clip.userId !== user.id) {
        return res.status(403).json({ message: "Forbidden" });
      }
      
      // Update clip with filter and trim data
      const updateData = {
        filter: req.body.filter,
        trimStart: req.body.trimStart,
        trimEnd: req.body.trimEnd
      };
      
      const updatedClip = await storage.updateClip(clipId, updateData);
      
      if (!updatedClip) {
        return res.status(500).json({ message: "Failed to update clip" });
      }
      
      res.status(200).json(updatedClip);
    } catch (err) {
      console.error(err);
      res.status(500).json({ message: "Internal server error" });
    }
  });

