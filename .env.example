SESSION_SECRET=z+lxBsRNyONsE+zieYeHlVTCUDdxGJDgKyoV1N+4pwM=

# Email Service Configuration (Brevo)
BREVO_API_KEY=your_brevo_api_key_here

# Custom Domain Configuration (for share links)
# Set this to your custom domain when deploying (e.g., beta.gamefolio.com)
CUSTOM_DOMAIN=

# Video Ad Tag (VAST/VPAID URL from Google Ad Manager or another video SSP).
# Leave empty to disable video preroll ads on clips/reels entirely.
# When empty, the IMA SDK is never loaded and the ad slot is skipped.
VITE_AD_TAG_URL=

# Google AdSense publisher ID (e.g. ca-pub-1234567890123456).
# Leave empty to skip loading adsbygoogle.js entirely.
VITE_ADSENSE_CLIENT_ID=

# Sentry crash/error reporting (Capacitor + WebView).
# Leave VITE_SENTRY_DSN empty to disable Sentry entirely (no-op). Set it to the
# DSN from your Sentry project (Settings → Client Keys) to turn capture on.
VITE_SENTRY_DSN=
# Optional override for the Sentry environment tag (defaults to
# production/development based on the build mode).
VITE_SENTRY_ENVIRONMENT=
# Optional: only needed to upload sourcemaps so minified stack traces become
# readable. When SENTRY_AUTH_TOKEN is set, `vite build` uploads maps for the
# release and deletes them afterwards. Org/project are the Sentry slugs.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=