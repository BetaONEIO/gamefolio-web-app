  // User operations
  async getUser(id: number): Promise<User | undefined> {
    return this.users.get(id);
  }

  async getUserByUsername(username: string): Promise<User | undefined> {
    return Array.from(this.users.values()).find(
      (user) => user.username.toLowerCase() === username.toLowerCase(),
    );
  }

  async createUser(userData: InsertUser): Promise<User> {
    const id = this.currentUserId++;
    const now = new Date();
    const user: User = { 
      id,
      username: userData.username,
      password: userData.password,
      email: userData.email || null,
      emailVerified: userData.emailVerified || false,
      displayName: userData.displayName || '',
      bio: userData.bio || null,
      avatarUrl: userData.avatarUrl || null,
      bannerUrl: userData.bannerUrl || null,
      accentColor: userData.accentColor || "#4C8",
      primaryColor: userData.primaryColor || "#02172C",
      layoutStyle: userData.layoutStyle || "grid",
      steamUsername: userData.steamUsername || null,
      xboxUsername: userData.xboxUsername || null,
      playstationUsername: userData.playstationUsername || null,
      twitterUsername: userData.twitterUsername || null,
      youtubeUsername: userData.youtubeUsername || null,
      createdAt: now,
      updatedAt: now
    };
    this.users.set(id, user);
    return user;
  }

  async updateUser(id: number, userData: Partial<User>): Promise<User | undefined> {
    const user = await this.getUser(id);
    if (!user) return undefined;
    
    const updatedUser: User = { 
      ...user, 
      ...userData, 
      updatedAt: new Date() 
    };
    
    this.users.set(id, updatedUser);
    return updatedUser;
  }

  async getUserWithStats(id: number): Promise<UserWithStats | undefined> {
    const user = await this.getUser(id);
    if (!user) return undefined;
    
    const followers = await this.getFollowersByUserId(id);
    const following = await this.getFollowingByUserId(id);
    const userClips = await this.getClipsByUserId(id);
    const favoriteGames = await this.getUserGameFavorites(id);
    
    const totalViews = userClips.reduce((sum, clip) => sum + clip.views, 0);
    
    return {
      ...user,
      _count: {
        followers: followers.length,
        following: following.length,
        clips: userClips.length,
        clipViews: totalViews
      },
      favoriteGames
    };
  }

  // Game operations
  async getGame(id: number): Promise<Game | undefined> {
    return this.games.get(id);
  }

  async getGameByName(name: string): Promise<Game | undefined> {
    return Array.from(this.games.values()).find(
      (game) => game.name.toLowerCase() === name.toLowerCase(),
    );
  }

  async createGame(gameData: InsertGame): Promise<Game> {
    const id = this.currentGameId++;
    const now = new Date();
    const game: Game = { 
      id,
      name: gameData.name,
      imageUrl: gameData.imageUrl || null,
      createdAt: now
    };
    this.games.set(id, game);
    return game;
  }

  async getAllGames(): Promise<Game[]> {
    return Array.from(this.games.values());
  }

  async getTrendingGames(limit: number = 10): Promise<Game[]> {
    // In a real app, this would calculate trends based on clip views, likes, etc.
    // For now, just return all games with a random sorting to simulate "trending"
    const games = Array.from(this.games.values());
    return games.sort(() => Math.random() - 0.5).slice(0, limit);
  }

  // Clip operations
  async getClip(id: number): Promise<Clip | undefined> {
    return this.clips.get(id);
  }

  async getClipWithUser(id: number): Promise<ClipWithUser | undefined> {
    const clip = await this.getClip(id);
    if (!clip) return undefined;
    
    const user = await this.getUser(clip.userId);
    if (!user) return undefined;
    
    const game = clip.gameId ? await this.getGame(clip.gameId) : undefined;
    const likes = await this.getLikesByClipId(id);
    const comments = await this.getCommentsByClipId(id);
    
    return {
      ...clip,
      user,
      game,
      _count: {
        likes: likes.length,
        comments: comments.length
      }
    };
  }

  async createClip(clipData: InsertClip): Promise<Clip> {
    const id = this.currentClipId++;
    const now = new Date();
    const clip: Clip = { 
      id,
      userId: clipData.userId,
      title: clipData.title,
      videoUrl: clipData.videoUrl,
      gameId: clipData.gameId || null,
      description: clipData.description || null,
      thumbnailUrl: clipData.thumbnailUrl || null,
      duration: clipData.duration || null,
      views: 0,
      tags: clipData.tags || null,
      filter: clipData.filter || "none",
      trimStart: clipData.trimStart || 0,
      trimEnd: clipData.trimEnd || 0,
      createdAt: now
    };
    this.clips.set(id, clip);
    return clip;
  }

  async updateClip(id: number, clipData: Partial<Clip>): Promise<Clip | undefined> {
    const clip = await this.getClip(id);
    if (!clip) return undefined;
    
    // Ensure tags field is properly handled
    const updatedClip: Clip = { 
      ...clip, 
      ...clipData,
      tags: clipData.tags !== undefined ? clipData.tags : clip.tags
    };
    
    this.clips.set(id, updatedClip);
    return updatedClip;
  }

  async deleteClip(id: number): Promise<boolean> {
    const exists = this.clips.has(id);
    if (!exists) return false;
    
    // Delete related likes and comments
    const likes = await this.getLikesByClipId(id);
    for (const like of likes) {
      this.likes.delete(like.id);
    }
    
    const comments = await this.getCommentsByClipId(id);
    for (const comment of comments) {
      this.comments.delete(comment.id);
    }
    
    return this.clips.delete(id);
  }

  async incrementClipViews(id: number): Promise<void> {
    const clip = await this.getClip(id);
    if (!clip) return;
    
    const updatedClip: Clip = { 
      ...clip, 
      views: clip.views + 1
    };
    
    this.clips.set(id, updatedClip);
  }

  async getClipsByUserId(userId: number): Promise<ClipWithUser[]> {
    const userClips = Array.from(this.clips.values())
      .filter(clip => clip.userId === userId);
    
    const clipsWithDetails: ClipWithUser[] = [];
    
    for (const clip of userClips) {
      const clipWithUser = await this.getClipWithUser(clip.id);
      if (clipWithUser) {
        clipsWithDetails.push(clipWithUser);
      }
    }
    
    return clipsWithDetails.sort((a, b) => 
      b.createdAt.getTime() - a.createdAt.getTime()
    );
  }
  
  async getClipsByGameId(gameId: number, limit: number = 4): Promise<ClipWithUser[]> {
    const gameClips = Array.from(this.clips.values())
      .filter(clip => clip.gameId === gameId)
      .sort((a, b) => b.views - a.views)
      .slice(0, limit);
    
    const clipsWithDetails: ClipWithUser[] = [];
    
    for (const clip of gameClips) {
      const clipWithUser = await this.getClipWithUser(clip.id);
      if (clipWithUser) {
        clipsWithDetails.push(clipWithUser);
      }
    }
    
    return clipsWithDetails;
  }

  async getFeedClips(period: string = 'day', limit: number = 10): Promise<ClipWithUser[]> {
    const allClips = Array.from(this.clips.values());
    
    // If we have no clips, create some sample data
    if (allClips.length === 0) {
      await this.initializeSampleClips();
      return this.getFeedClips(period, limit);
    }
    
    // Adjust time filters to ensure we always show something
    // For the sample clips in memory storage, we'll pretend they're all recent
    let filteredClips = allClips;
    
    // Sort by views and get top clips
    const topClips = filteredClips.sort((a, b) => b.views - a.views).slice(0, limit);
    
    const clipsWithDetails: ClipWithUser[] = [];
    
    for (const clip of topClips) {
      const clipWithUser = await this.getClipWithUser(clip.id);
      if (clipWithUser) {
        clipsWithDetails.push(clipWithUser);
      }
    }
    
    return clipsWithDetails;
  }

  // Like operations
  async createLike(likeData: InsertLike): Promise<Like> {
    // Check if like already exists
    const exists = await this.hasUserLikedClip(likeData.userId, likeData.clipId);
    if (exists) {
      throw new Error("User has already liked this clip");
    }
    
    const id = this.currentLikeId++;
    const now = new Date();
    const like: Like = { 
      ...likeData, 
      id, 
      createdAt: now 
    };
    this.likes.set(id, like);
    return like;
  }

  async deleteLike(userId: number, clipId: number): Promise<boolean> {
    const like = Array.from(this.likes.values()).find(
      like => like.userId === userId && like.clipId === clipId
    );
    
    if (!like) return false;
    return this.likes.delete(like.id);
  }

  async getLikesByClipId(clipId: number): Promise<Like[]> {
    return Array.from(this.likes.values()).filter(
      like => like.clipId === clipId
    );
  }

  async getLikesByUserId(userId: number): Promise<Like[]> {
    return Array.from(this.likes.values()).filter(
      like => like.userId === userId
    );
  }

  async hasUserLikedClip(userId: number, clipId: number): Promise<boolean> {
    return Array.from(this.likes.values()).some(
      like => like.userId === userId && like.clipId === clipId
    );
  }

  // Comment operations
  async getComment(id: number): Promise<Comment | undefined> {
    return this.comments.get(id);
  }

  async createComment(commentData: InsertComment): Promise<Comment> {
    const id = this.currentCommentId++;
    const now = new Date();
    const comment: Comment = { 
      ...commentData, 
      id, 
      createdAt: now 
    };
    this.comments.set(id, comment);
    return comment;
  }

  async getCommentsByClipId(clipId: number): Promise<Comment[]> {
    return Array.from(this.comments.values())
      .filter(comment => comment.clipId === clipId)
      .sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());
  }

  async deleteComment(id: number): Promise<boolean> {
    return this.comments.delete(id);
  }

  // User game favorites operations
  async addUserGameFavorite(favoriteData: InsertUserGameFavorite): Promise<UserGameFavorite> {
    // Check if already exists
    const exists = Array.from(this.userGameFavorites.values()).some(
      fav => fav.userId === favoriteData.userId && fav.gameId === favoriteData.gameId
    );
    
    if (exists) {
      throw new Error("User has already favorited this game");
    }
    
    const id = this.currentUserGameFavoriteId++;
    const now = new Date();
    const favorite: UserGameFavorite = { 
      ...favoriteData, 
      id, 
      createdAt: now 
    };
    this.userGameFavorites.set(id, favorite);
    return favorite;
  }
  
  // A safe way to add user game favorites that doesn't throw if already exists
  private safeAddUserGameFavorite(userId: number, gameId: number): void {
    // Check if the user already has this game as a favorite
    const exists = Array.from(this.userGameFavorites.values()).some(
      fav => fav.userId === userId && fav.gameId === gameId
    );
    
    if (exists) {
      return; // Already exists, just skip
    }
    
    // Add new favorite
    const id = this.currentUserGameFavoriteId++;
    const now = new Date();
    const favorite: UserGameFavorite = {
      userId,
      gameId,
      id,
      createdAt: now
    };
    
    this.userGameFavorites.set(id, favorite);
  }

  async removeUserGameFavorite(userId: number, gameId: number): Promise<boolean> {
    const favorite = Array.from(this.userGameFavorites.values()).find(
      fav => fav.userId === userId && fav.gameId === gameId
    );
    
    if (!favorite) return false;
    return this.userGameFavorites.delete(favorite.id);
  }

  async getUserGameFavorites(userId: number): Promise<Game[]> {
    const favorites = Array.from(this.userGameFavorites.values())
      .filter(fav => fav.userId === userId);
    
    const gameIds = favorites.map(fav => fav.gameId);
    const games: Game[] = [];
    
    for (const gameId of gameIds) {
      const game = await this.getGame(gameId);
      if (game) games.push(game);
    }
    
    return games;
  }

  // Follow operations
  async createFollow(followData: InsertFollow): Promise<Follow> {
    // Check if already following
    const exists = await this.isFollowing(followData.followerId, followData.followingId);
    if (exists) {
      throw new Error("User is already following this user");
    }
    
    const id = this.currentFollowId++;
    const now = new Date();
    const follow: Follow = { 
      ...followData, 
      id, 
      createdAt: now 
    };
    this.follows.set(id, follow);
    return follow;
  }

  async deleteFollow(followerId: number, followingId: number): Promise<boolean> {
    const follow = Array.from(this.follows.values()).find(
      follow => follow.followerId === followerId && follow.followingId === followingId
    );
    
    if (!follow) return false;
    return this.follows.delete(follow.id);
  }

  async getFollowersByUserId(userId: number): Promise<User[]> {
    const followers = Array.from(this.follows.values())
      .filter(follow => follow.followingId === userId)
      .map(follow => follow.followerId);
    
    const users: User[] = [];
    
    for (const followerId of followers) {
      const user = await this.getUser(followerId);
      if (user) users.push(user);
    }
    
    return users;
  }

  async getFollowingByUserId(userId: number): Promise<User[]> {
    const following = Array.from(this.follows.values())
      .filter(follow => follow.followerId === userId)
      .map(follow => follow.followingId);
    
    const users: User[] = [];
    
    for (const followingId of following) {
      const user = await this.getUser(followingId);
      if (user) users.push(user);
    }
    
    return users;
  }

  async isFollowing(followerId: number, followingId: number): Promise<boolean> {
    return Array.from(this.follows.values()).some(
      follow => follow.followerId === followerId && follow.followingId === followingId
    );
  }

  async getFollowerCount(userId: number): Promise<number> {
    return (await this.getFollowersByUserId(userId)).length;
  }

  async getFollowingCount(userId: number): Promise<number> {
    return (await this.getFollowingByUserId(userId)).length;
  }

  // Search operations
  async searchUsers(query: string): Promise<User[]> {
    const lowercaseQuery = query.toLowerCase();
    return Array.from(this.users.values()).filter(
      user => user.username.toLowerCase().includes(lowercaseQuery) ||
              user.displayName.toLowerCase().includes(lowercaseQuery)
    );
  }

  async searchGames(query: string): Promise<Game[]> {
    const lowercaseQuery = query.toLowerCase();
    return Array.from(this.games.values()).filter(
      game => game.name.toLowerCase().includes(lowercaseQuery)
    );
  }

  async searchClips(query: string): Promise<ClipWithUser[]> {
    const lowercaseQuery = query.toLowerCase();
    const matchingClips = Array.from(this.clips.values()).filter(
      clip => clip.title.toLowerCase().includes(lowercaseQuery) ||
              (clip.description && clip.description.toLowerCase().includes(lowercaseQuery))
    );
    
    const clipsWithDetails: ClipWithUser[] = [];
    
    for (const clip of matchingClips) {
      const clipWithUser = await this.getClipWithUser(clip.id);
      if (clipWithUser) {
        clipsWithDetails.push(clipWithUser);
      }
    }
    
    return clipsWithDetails;
  }

  // Profile customization operations
  async getAllProfileBanners(): Promise<ProfileBanner[]> {
    return Array.from(this.profileBanners.values())
      .sort((a, b) => a.name.localeCompare(b.name));
  }

  async getProfileBannersByCategory(category: string): Promise<ProfileBanner[]> {
    return Array.from(this.profileBanners.values())
      .filter(banner => banner.category === category)
      .sort((a, b) => a.name.localeCompare(b.name));
  }
}

// Use DatabaseStorage when database is enabled, otherwise use MemStorage
import { DatabaseStorage } from "./database-storage";

// Check if we have a database connection
const useDatabaseStorage = !!process.env.DATABASE_URL;

// Use memory storage due to database connection issues
export const storage = new MemStorage();
