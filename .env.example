SESSION_SECRET=z+lxBsRNyONsE+zieYeHlVTCUDdxGJDgKyoV1N+4pwM=

# Email Service Configuration (Brevo)
BREVO_API_KEY=your_brevo_api_key_here

# Custom Domain Configuration (for share links)
# Set this to your custom domain when deploying (e.g., beta.gamefolio.com)
CUSTOM_DOMAIN=

# Video Ad Tag (VAST/VPAID URL from Google Ad Manager or another video SSP).
# Leave empty to disable video preroll ads on clips/reels entirely.
# When empty, the IMA SDK is never loaded and the ad slot is skipped.
VITE_AD_TAG_URL=

# Google AdSense publisher ID (e.g. ca-pub-1234567890123456).
# Leave empty to skip loading adsbygoogle.js entirely.
VITE_ADSENSE_CLIENT_ID=

# Live streaming (OBS → Cloudflare Stream). Partner-gated; see /studio.
# Without these the streaming endpoints return 503 and the studio shows a setup error.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=          # API token with the "Stream:Edit" permission
CLOUDFLARE_STREAM_DOMAIN=             # customer playback subdomain, e.g. customer-abc123.cloudflarestream.com
CLOUDFLARE_STREAM_WEBHOOK_SECRET=     # optional: verifies live-input connect/disconnect webhooks